#!/usr/bin/env bash
# Tracker CLI — YouGile.
# Сгенерирован скиллом carono-wf:tracker-setup через discovery живого API
# (проба каждого эндпоинта перед написанием маппинга). Не редактировать руками —
# при следующем запуске скилла будет перезаписан.
#
# Контракт CLI: см. skills/tracker-setup/cli-contract.md в плагине.
# Все команды stdout -> JSON, stderr -> ошибки.
# Коды: 0 ok, 1 bad-usage, 2 config, 3 not-found, 4 network/api.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$BOT_DIR/.env"

[[ -f "$ENV_FILE" ]] || { echo "ERROR: .env not found at $ENV_FILE" >&2; exit 2; }
# shellcheck disable=SC1090
set -a; source "$ENV_FILE"; set +a

: "${TRACKER_API_KEY:?TRACKER_API_KEY is not set in .env}"
: "${TRACKER_BASE_URL:?TRACKER_BASE_URL is not set in .env}"
: "${TRACKER_BOARD_ID:?TRACKER_BOARD_ID is not set in .env}"
: "${TRACKER_BOT_LOGIN:=}"
: "${YOUGILE_TEAM_ID:=}"
: "${YOUGILE_PROJECT_NAME:=}"

for dep in curl jq; do
  command -v "$dep" >/dev/null 2>&1 || { echo "ERROR: $dep not installed" >&2; exit 2; }
done

AUTH=(-H "Authorization: Bearer $TRACKER_API_KEY" -H "Content-Type: application/json" -H "Accept: application/json")

# ───────── HTTP helpers ─────────

api_get() {
  local path="$1" out
  if ! out=$(curl -sS --fail-with-body "${AUTH[@]}" "$TRACKER_BASE_URL$path" 2>&1); then
    echo "ERROR: GET $path: $out" >&2
    return 4
  fi
  printf '%s' "$out"
}

api_post() {
  local path="$1" body="$2" out
  if ! out=$(curl -sS --fail-with-body "${AUTH[@]}" -X POST -d "$body" "$TRACKER_BASE_URL$path" 2>&1); then
    echo "ERROR: POST $path: $out" >&2
    return 4
  fi
  printf '%s' "$out"
}

api_put() {
  local path="$1" body="$2" out
  if ! out=$(curl -sS --fail-with-body "${AUTH[@]}" -X PUT -d "$body" "$TRACKER_BASE_URL$path" 2>&1); then
    echo "ERROR: PUT $path: $out" >&2
    return 4
  fi
  printf '%s' "$out"
}

# ───────── resolvers ─────────

resolve_column_id() {
  local name="$1"
  api_get "/columns?boardId=$TRACKER_BOARD_ID&limit=1000" \
    | jq -r --arg n "$name" '.content[] | select(.title == $n) | .id' \
    | head -n1
}

resolve_column_name() {
  local id="$1"
  api_get "/columns?boardId=$TRACKER_BOARD_ID&limit=1000" \
    | jq -r --arg id "$id" '.content[] | select(.id == $id) | .title' \
    | head -n1
}

resolve_user_id() {
  local login="$1"
  [[ "$login" == "me" ]] && login="$TRACKER_BOT_LOGIN"
  api_get "/users?limit=1000" \
    | jq -r --arg login "$login" '.content[] | select(.realName == $login or .email == $login) | .id' \
    | head -n1
}

# ───────── commands ─────────

cmd_whoami() {
  [[ -z "$TRACKER_BOT_LOGIN" ]] && { echo '{"error":"TRACKER_BOT_LOGIN is empty in .env"}' >&2; return 2; }
  # YouGile не имеет /auth/me — идём через /users с фильтром
  local users me
  users=$(api_get "/users?limit=1000") || return $?
  me=$(echo "$users" | jq --arg login "$TRACKER_BOT_LOGIN" '
    .content[] | select(.realName == $login or .email == $login)
    | {id, login: (.realName // .email // ""), name: (.realName // .email // ""), email: (.email // "")}
  ')
  if [[ -z "$me" ]]; then
    echo "{\"error\":\"user '$TRACKER_BOT_LOGIN' not found in project\"}" >&2
    return 3
  fi
  echo "$me"
}

cmd_list_columns() {
  api_get "/columns?boardId=$TRACKER_BOARD_ID&limit=1000" \
    | jq '[.content | to_entries[] | {id: .value.id, name: .value.title, position: .key}]'
}

cmd_list_tasks() {
  local column="" assignee="" limit=50
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --column) column="$2"; shift 2 ;;
      --assignee) assignee="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      *) echo "ERROR: unknown flag '$1'" >&2; exit 1 ;;
    esac
  done
  [[ -z "$column" ]] && { echo "ERROR: --column required" >&2; exit 1; }

  local col_id
  col_id=$(resolve_column_id "$column")
  [[ -z "$col_id" ]] && { echo "ERROR: column '$column' not found" >&2; exit 3; }

  local raw
  raw=$(api_get "/task-list?columnId=$col_id&limit=$limit") || return $?

  local assignee_id="" mode="$assignee"
  if [[ -n "$assignee" && "$assignee" != "none" ]]; then
    assignee_id=$(resolve_user_id "$assignee")
    [[ -z "$assignee_id" ]] && { echo "ERROR: user '$assignee' not found" >&2; exit 3; }
  fi

  echo "$raw" | jq \
    --arg column "$column" \
    --arg mode "$mode" \
    --arg assignee_id "$assignee_id" \
    --arg team "$YOUGILE_TEAM_ID" \
    --arg project "$YOUGILE_PROJECT_NAME" \
    '[.content[]
      | select(
          ($mode == "") or
          ($mode == "none" and ((.assigned // []) | length == 0)) or
          ($mode != "none" and ((.assigned // []) | index($assignee_id) != null))
        )
      | {
          id,
          number: (.idTaskProject // ""),
          title,
          column: $column,
          assignees: (.assigned // []),
          url: (if ($team != "" and $project != "" and (.idTaskProject // "") != "")
                then "https://ru.yougile.com/team/" + $team + "/" + $project + "#" + .idTaskProject
                else "" end),
          updated_at: (((.timestamp // 0) / 1000) | todate)
        }
    ]'
}

cmd_get_task() {
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "ERROR: task id required" >&2; exit 1; }
  local raw col_name
  raw=$(api_get "/tasks/$id") || { echo '{"error":"not found"}'; return 3; }
  col_name=$(resolve_column_name "$(echo "$raw" | jq -r '.columnId // ""')")
  echo "$raw" | jq --arg column "$col_name" \
    --arg team "$YOUGILE_TEAM_ID" --arg project "$YOUGILE_PROJECT_NAME" '{
      id,
      number: (.idTaskProject // ""),
      title,
      description: "",
      column: $column,
      assignees: (.assigned // []),
      url: (if ($team != "" and $project != "" and (.idTaskProject // "") != "")
            then "https://ru.yougile.com/team/" + $team + "/" + $project + "#" + .idTaskProject
            else "" end),
      created_at: (((.timestamp // 0) / 1000) | todate),
      updated_at: (((.timestamp // 0) / 1000) | todate)
    }'
}

cmd_list_comments() {
  local id="${1:-}"; shift || true
  [[ -z "$id" ]] && { echo "ERROR: task id required" >&2; exit 1; }
  local since="" limit=100
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since) since="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      *) echo "ERROR: unknown flag '$1'" >&2; exit 1 ;;
    esac
  done
  local raw
  raw=$(api_get "/chats/$id/messages?limit=$limit") || return $?
  echo "$raw" | jq --arg since "$since" '
    [.content[]
     | select($since == "" or ((.id // 0) | tostring) > $since)
     | {
         id,
         author: (.fromUserId // ""),
         text: (.text // ""),
         created_at: (((.id // 0) / 1000) | todate)
       }
    ] | sort_by(.id)'
}

cmd_comment() {
  local id="${1:-}"; shift || true
  [[ -z "$id" ]] && { echo "ERROR: task id required" >&2; exit 1; }
  local text=""
  if [[ "${1:-}" == "--file" ]]; then
    text="$(cat "$2")"
    shift 2
  elif [[ -n "${1:-}" ]]; then
    text="$1"
    shift
  fi
  [[ -z "$text" ]] && { echo "ERROR: text required (positional or --file)" >&2; exit 1; }

  local body resp
  body=$(jq -n --arg t "$text" '{text: $t}')
  resp=$(api_post "/chats/$id/messages" "$body") || return $?
  echo "$resp" | jq '{id, created_at: (((.id // 0) / 1000) | todate)}'
}

cmd_move_task() {
  local id="${1:-}"; shift || true
  [[ -z "$id" ]] && { echo "ERROR: task id required" >&2; exit 1; }
  local column=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --column) column="$2"; shift 2 ;;
      *) echo "ERROR: unknown flag '$1'" >&2; exit 1 ;;
    esac
  done
  [[ -z "$column" ]] && { echo "ERROR: --column required" >&2; exit 1; }

  local col_id
  col_id=$(resolve_column_id "$column")
  [[ -z "$col_id" ]] && { echo "ERROR: column '$column' not found" >&2; exit 3; }

  api_put "/tasks/$id" "$(jq -n --arg c "$col_id" '{columnId: $c}')" >/dev/null || return $?
  jq -n --arg id "$id" --arg col "$column" '{ok: true, id: $id, column: $col}'
}

cmd_assign_task() {
  local id="${1:-}"; shift || true
  [[ -z "$id" ]] && { echo "ERROR: task id required" >&2; exit 1; }
  local user=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user) user="$2"; shift 2 ;;
      *) echo "ERROR: unknown flag '$1'" >&2; exit 1 ;;
    esac
  done
  [[ -z "$user" ]] && { echo "ERROR: --user required" >&2; exit 1; }

  local body
  if [[ "$user" == "none" ]]; then
    body='{"assigned": []}'
  else
    local uid
    uid=$(resolve_user_id "$user")
    [[ -z "$uid" ]] && { echo "ERROR: user '$user' not found" >&2; exit 3; }
    body=$(jq -n --arg u "$uid" '{assigned: [$u]}')
  fi

  # YouGile возвращает с PUT только {id} — для актуального assigned делаем GET
  api_put "/tasks/$id" "$body" >/dev/null || return $?
  api_get "/tasks/$id" \
    | jq --arg id "$id" '{ok: true, id: $id, assignees: (.assigned // [])}'
}

cmd_create_task() {
  local title="" column="" description="" description_file=""
  local -a assignees=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title) title="$2"; shift 2 ;;
      --column) column="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --description-file) description_file="$2"; shift 2 ;;
      --assignee) assignees+=("$2"); shift 2 ;;
      *) echo "ERROR: unknown flag '$1'" >&2; exit 1 ;;
    esac
  done
  [[ -z "$title" ]] && { echo "ERROR: --title required" >&2; exit 1; }
  [[ -n "$description_file" ]] && description="$(cat "$description_file")"

  local col_id=""
  if [[ -n "$column" ]]; then
    col_id=$(resolve_column_id "$column")
    [[ -z "$col_id" ]] && { echo "ERROR: column '$column' not found" >&2; exit 3; }
  fi

  local -a assignee_ids=()
  if (( ${#assignees[@]} > 0 )); then
    for login in "${assignees[@]}"; do
      [[ -z "$login" ]] && continue
      local uid
      uid=$(resolve_user_id "$login")
      [[ -n "$uid" ]] && assignee_ids+=("$uid")
    done
  fi

  local users_json="[]"
  if (( ${#assignee_ids[@]} > 0 )); then
    users_json=$(printf '%s\n' "${assignee_ids[@]}" | jq -R . | jq -s .)
  fi

  local body
  body=$(jq -n \
    --arg title "$title" \
    --arg col "$col_id" \
    --argjson users "$users_json" \
    '{title: $title}
     + (if $col != "" then {columnId: $col} else {} end)
     + (if ($users | length) > 0 then {assigned: $users} else {} end)')

  local resp created_id
  resp=$(api_post "/tasks" "$body") || return $?
  created_id=$(echo "$resp" | jq -r '.id // ""')
  [[ -z "$created_id" ]] && { echo "ERROR: create failed — no id in response: $resp" >&2; return 4; }

  # YouGile REST не имеет поля description в задачах (проверено discovery).
  # Содержательное описание принято класть первым сообщением в чате.
  if [[ -n "$description" ]]; then
    api_post "/chats/$created_id/messages" "$(jq -n --arg t "$description" '{text: $t}')" >/dev/null || true
  fi

  # POST /tasks возвращает только {id} — для number (idTaskProject) делаем GET
  api_get "/tasks/$created_id" \
    | jq --arg team "$YOUGILE_TEAM_ID" --arg project "$YOUGILE_PROJECT_NAME" '{
        id,
        number: (.idTaskProject // ""),
        url: (if ($team != "" and $project != "" and (.idTaskProject // "") != "")
              then "https://ru.yougile.com/team/" + $team + "/" + $project + "#" + .idTaskProject
              else "" end)
      }'
}

cmd_delete_task() {
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "ERROR: task id required" >&2; exit 1; }
  api_put "/tasks/$id" '{"deleted": true}' >/dev/null || return $?
  jq -n --arg id "$id" '{ok: true, id: $id}'
}

cmd_list_users() {
  api_get "/users?limit=1000" \
    | jq '[.content[] | {
        id,
        login: (.realName // .email // ""),
        name: (.realName // .email // ""),
        email: (.email // "")
      }]'
}

usage() {
  cat >&2 <<EOF
Usage: tracker <command> [args]

  whoami
  list-columns
  list-tasks --column <name> [--assignee <login|me|none>] [--limit N]
  get-task <id>
  list-comments <id> [--since <comment-id>] [--limit N]
  comment <id> <text>  |  comment <id> --file <path>
  move-task <id> --column <name>
  assign-task <id> --user <login|me|none>
  create-task --title <t> [--column <c>] [--description <d>] [--description-file <p>] [--assignee <u>]...
  delete-task <id>
  list-users

Note (YouGile): get-task.description всегда пустое — в REST YouGile нет поля
description у задач. Содержательное описание хранится первым сообщением в чате
(читай через list-comments).
EOF
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    whoami)        cmd_whoami "$@" ;;
    list-columns)  cmd_list_columns "$@" ;;
    list-tasks)    cmd_list_tasks "$@" ;;
    get-task)      cmd_get_task "$@" ;;
    list-comments) cmd_list_comments "$@" ;;
    comment)       cmd_comment "$@" ;;
    move-task)     cmd_move_task "$@" ;;
    assign-task)   cmd_assign_task "$@" ;;
    create-task)   cmd_create_task "$@" ;;
    delete-task)   cmd_delete_task "$@" ;;
    list-users)    cmd_list_users "$@" ;;
    ""|-h|--help)  usage; exit 0 ;;
    *)             echo "ERROR: unknown command '$cmd'" >&2; usage; exit 1 ;;
  esac
}

main "$@"
